COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# Cloudflare R2 (almacenamiento del corpus crudo + productos en la nube).
# Solo se necesitan para los scripts scripts/r2_pull.sh / r2_push.sh y los
# workflows de GitHub Actions; el pipeline local no los usa. R2 es compatible
# con la API de S3: se accede vía aws-cli con --endpoint-url. Los tokens se
# crean en el panel de Cloudflare (R2 → Manage API Tokens).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Opcional: si se define, tiene prioridad sobre R2_ACCOUNT_ID para el endpoint.
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Región de estudio del pipeline (alcance geográfico). Ver processing/utils/regions.py.
# Hojas (una región): arica · tarapaca · antofagasta · atacama (por defecto) ·
#   coquimbo · valparaiso · ohiggins · maule · nuble · biobio · araucania ·
#   los_rios · los_lagos · aysen · magallanes · caldera (sub-perfil de atacama)
# Macro-zonas (unión de regiones): norte_grande · norte_chico · norte · centro ·
#   centro_sur · sur · austral · chile
REGION=atacama
